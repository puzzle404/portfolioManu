<nav class="finance-navbar">
  <div class="d-flex align-items-center justify-content-between px-3 py-2">
    <div class="d-flex align-items-center gap-2">
      <%= link_to root_path, class: "text-decoration-none" do %>
        <%= image_tag "m.png", height: 28, style: "height: 28px; width: auto;" %>
      <% end %>
      <span class="text-light fw-bold"><%= content_for?(:finance_title) ? content_for(:finance_title) : "ManuFinance" %></span>
    </div>
    <div class="d-flex align-items-center gap-3">
      <% if content_for?(:finance_nav_actions) %>
        <%= content_for(:finance_nav_actions) %>
      <% end %>
      <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "text-light" do %>
        <i class="fas fa-sign-out-alt"></i>
      <% end %>
    </div>
  </div>
</nav>
