<%= link_to project_path(project), class: 'text-decoration-none color-w' do %>
  <div class="experience-item d-flex gap-3 my-5">
    <% if project.photos.attached? && project.photos.first %>
      <%= cl_image_tag project.photos.first.key, class: 'img-project rounded border-2 mt-1' %>
    <% else %>
      <div class="img-project-placeholder rounded border-2 mt-1 d-flex align-items-center justify-content-center" style="width: 120px; height: 80px; background: rgba(100, 255, 218, 0.1); border: 1px solid rgba(100, 255, 218, 0.3);">
        <i class="fas fa-code" style="color: #64ffda; font-size: 24px;"></i>
      </div>
    <% end %>
    <div class="card-text">
      <div class="d-flex gap-5 align-items-center">
        <h5><%= project.name %></h5>
        <i class="fas fa-external-link-alt icon-card-open mb-2"></i>
      </div>
      <%# <h5>Senior Frontend Engineer, Accessibility · Klaviyo <i class="fas fa-external-link-alt"></i></h5> %>
      <p><%= project.short_description %>.</p>
      <% project.skills.first(5).each do |skill| %>
        <span class="badge my-1"><%= skill.name %></span>
      <% end %>
      <span><%= project.skills.count > 5 ? '....' : '' %></span>
    </div>
  </div>
<% end %>
